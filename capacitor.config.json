{
  "appId": "com.conte.uasmanager",
  "appName": "UAS Manager",
  "webDir": "www",
  "server": {
    "androidScheme": "https"
  },
  "ios": {
    "contentInset": "always",
    "allowsLinkPreview": false,
    "backgroundColor": "#F0F4FA",
    "limitsNavigationsToAppBoundDomains": true
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#0C447C",
      "showSpinner": false
    }
  }
}

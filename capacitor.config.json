{
  "appId": "com.conteops.uasmanager",
  "appName": "UAS Manager",
  "webDir": ".",
  "ios": {
    "scheme": "UASManager",
    "backgroundColor": "#0C447C",
    "contentInset": "always",
    "preferredContentMode": "mobile",
    "minVersion": "14.5",
    "scrollEnabled": false
  },
  "plugins": {
    "StatusBar": {
      "style": "LIGHT",
      "backgroundColor": "#0C447C",
      "overlaysWebView": false
    },
    "Geolocation": {
      "permissions": {
        "ios": "whenInUse"
      }
    },
    "LocalNotifications": {
      "iconColor": "#0C447C"
    },
    "SplashScreen": {
      "launchShowDuration": 1200,
      "backgroundColor": "#0C447C",
      "showSpinner": false,
      "iosSpinnerStyle": "small",
      "launchAutoHide": true
    }
  }
}
